# --- Theme ---
# theme = 0x96f
# theme = Tokyonight night
# theme = Catppuccin Mocha
background = 000000
 
# --- Background & Blur ---
background-opacity = 0.80
background-blur-radius = 55

# --- Font Rendering ---
font-family = Meslolgs Nerd Font
# font-family =   CaskaydiaCove NF SemiLight
# font-family =   Blexmono nerd font
# font-family = Recmonocasual nerd font
font-size = 12
font-thicken = true   

# --- Cursor ---    
# Changes the cursor shape to an underscore
cursor-style = underline
# Increases the thickness of the cursor (1 is default)
adjust-cursor-thickness = 1
# Prevents the shell from overriding your custom cursor shape
shell-integration-features = no-cursor

# --- Window & Tabs (macOS) ---
# Places the tab bar directly inline with the macOS traffic light buttons
macos-titlebar-style = tabs
window-padding-color = background

# --- Clipboard ---
# Automatically copies selected text to your system clipboard
copy-on-select = clipboard
clipboard-paste-protection = false

# --- Compatibility ---
# Disguises Ghostty as a standard terminal so remote servers recognize it
term = xterm-256color

# --- Custom Keybindings ---
# Maps Cmd+S to send the hex code for Ctrl+S (\x13)	
keybind = cmd+s=text:\x13
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
macos-option-as-alt = true
desktop-notifications = true

notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
notify-on-command-finish-after = 1s

mouse-scroll-multiplier = 1
window-padding-x = 5
window-padding-y = 10

