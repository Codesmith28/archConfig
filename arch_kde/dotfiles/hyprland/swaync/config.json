{
  "$schema": "/etc/swaync/config-schema.json",
  "notification-icon-size": 32,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 10,
  "timeout-critical": 0,
  "margin-top": 10,
  "margin-bottom": 10,
  "margin-right": 10,
  "margin-left": 0,
  "notification-window-width": 400,
  "control-center-width": 460,
  "control-center-height": 700,
  "control-center-margin-top": 10,
  "control-center-margin-right": 10,
  "control-center-margin-bottom": 10,
  "control-center-margin-left": 0,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": true,
  "hide-on-action": true,
  "fit-to-screen": false,
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "notifications",
    "buttons-grid"
  ],
  "widget-config": {
    "title": {
      "text": "Notification Center",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "label": {
      "max-lines": 8
    },
    "mpris": {
      "image-size": 56,
      "image-radius": 6
    },
    "buttons-grid": {
      "actions": [
        {"label": "󰐥  Shutdown", "command": "systemctl poweroff"},
        {"label": "󰜉  Reboot",   "command": "systemctl reboot"},
        {"label": "󰤄  Sleep",    "command": "systemctl suspend"},
        {"label": "󰍃  Logout",   "command": "hyprctl dispatch exit"}
      ]
    }
  },
  "scripts": {
    "example": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    }
  },
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low"
    }
  }
}
